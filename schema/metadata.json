{
  "autodetectionByPath": [
    {
      "schema": "kubernetes.schema.yaml",
      "pathList": ["**/{k8s,kubernetes,manifests}/**/*.y{a,}ml"]
    },
    {
      "schema": "github.schema.yaml",
      "pathList": [
        ".github/workflows/*.y{a,}ml",
        "**/.github/workflows/*.y{a,}ml"
      ]
    },
    {
      "schema": "docker.schema.yaml",
      "pathList": ["**/{docker-,}compose.y{a,}ml"]
    },
    {
      "schema": "gitlab.schema.yaml",
      "pathList": [
        ".gitlab-ci.y{a,}ml",
        "**/.gitlab-ci.y{a,}ml",
        ".gitlab/**/*.y{a,}ml",
        "**/.gitlab/**/*.y{a,}ml"
      ]
    },
    {
      "schema": "ansible.schema.yaml",
      "pathList": [
        "**/{playbooks,ansible}/**/*.y{a,}ml",
        "**/roles/*/{tasks,handlers,defaults,vars}/*.y{a,}ml"
      ]
    },
    {
      "schema": "openapi.schema.yaml",
      "pathList": ["**/{openapi,swagger}.y{a,}ml", "**/openapi/**/*.y{a,}ml"]
    },
    {
      "schema": "tosca.schema.yaml",
      "pathList": [
        "**/tosca/**/*.y{a,}ml",
        "**/tosca*.y{a,}ml",
        "**/*service-template*.y{a,}ml"
      ]
    }
  ]
}
